{
  "name": "@nodots-llc/gnubg-hints",
  "version": "4.6.4-staging.8",
  "description": "GNU Backgammon hint engine for Node.js with TypeScript support",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gnubg-hints-cli": "dist/cli.js"
  },
  "scripts": {
    "preinstall": "node -e \"if(parseInt(process.versions.node.split('.')[0],10)!==20){console.error('\\x1b[31mFATAL: Node.js 20.x required, found '+process.versions.node+'\\x1b[0m');process.exit(1)}\"",
    "configure": "node ./bin/run-node-gyp.js configure",
    "build:native": "node ./bin/run-node-gyp.js build",
    "build:ts": "tsc",
    "build:databases": "./scripts/generate-databases.sh",
    "build": "npm run build:databases && node ./bin/run-node-gyp.js build && tsc",
    "rebuild": "npm run build:databases && node ./bin/run-node-gyp.js rebuild && tsc",
    "test": "jest",
    "test:coverage": "jest --coverage --verbose",
    "install": "npm run build:databases && node ./bin/run-node-gyp.js rebuild",
    "publish:npm": "npm publish --access public",
    "prepublishOnly": "npm run build:databases && node ./bin/run-node-gyp.js build && tsc",
    "pretest": "node ./bin/run-node-gyp.js build"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "dependencies": {
    "@nodots-llc/backgammon-types": "file:../../types",
    "node-addon-api": "^7.0.0",
    "node-gyp": "^10.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  },
  "gypfile": true,
  "keywords": [
    "backgammon",
    "gnubg",
    "hints",
    "ai",
    "native",
    "addon",
    "typescript"
  ],
  "author": "",
  "license": "GPL-3.0"
}
